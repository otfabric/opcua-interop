{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/otfabric/opcua-interop/schemas/client-result.schema.json",
  "title": "opcua-interop client result",
  "description": "Schema for the single JSON object written to stdout by every opcua-interop client command.",
  "type": "object",
  "required": ["schemaVersion", "adapter", "operation", "success", "serviceResult", "results", "error"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0"
    },
    "adapter": {
      "type": "string",
      "enum": ["open62541", "milo"]
    },
    "operation": {
      "type": "string",
      "enum": [
        "endpoints", "read", "write", "browse", "call", "subscribe",
        "subscription-lifecycle", "event-subscribe", "history-read",
        "republish", "transfer-subscriptions"
      ]
    },
    "success": {
      "type": "boolean"
    },
    "serviceResult": {
      "$ref": "#/$defs/statusCode"
    },
    "results": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/endpointResult" },
          { "$ref": "#/$defs/readResult" },
          { "$ref": "#/$defs/writeResult" },
          { "$ref": "#/$defs/browseResult" },
          { "$ref": "#/$defs/subscribeResult" },
          { "$ref": "#/$defs/subscriptionLifecycleResult" },
          { "$ref": "#/$defs/eventSubscribeResult" },
          { "$ref": "#/$defs/historyReadResult" },
          { "$ref": "#/$defs/republishResult" },
          { "$ref": "#/$defs/transferSubscriptionsResult" }
        ]
      }
    },
    "error": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/errorObject" }
      ]
    }
  },
  "$defs": {
    "statusCode": {
      "type": "object",
      "required": ["name", "code", "severity"],
      "additionalProperties": false,
      "properties": {
        "name":     { "type": "string" },
        "code":     { "type": "integer", "minimum": 0 },
        "severity": { "type": "string", "enum": ["Good", "Uncertain", "Bad"] }
      }
    },
    "errorObject": {
      "type": "object",
      "required": ["category", "message"],
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "enum": ["input", "transport", "service", "timeout", "internal"]
        },
        "message": { "type": "string" }
      }
    },
    "endpointResult": {
      "type": "object",
      "required": ["url", "securityPolicy", "securityMode"],
      "additionalProperties": false,
      "properties": {
        "url":            { "type": "string" },
        "securityPolicy": { "type": "string" },
        "securityMode":   { "type": "string" }
      }
    },
    "readResult": {
      "type": "object",
      "required": ["nodeId", "statusCode", "dataType", "builtInType", "value"],
      "additionalProperties": false,
      "properties": {
        "nodeId":          { "type": "string" },
        "statusCode":      { "$ref": "#/$defs/statusCode" },
        "dataType":        { "type": "string" },
        "builtInType":     { "type": "integer", "minimum": 1, "maximum": 25 },
        "value":           {},
        "sourceTimestamp": { "type": "string" }
      }
    },
    "writeResult": {
      "type": "object",
      "required": ["nodeId", "statusCode"],
      "additionalProperties": false,
      "properties": {
        "nodeId":     { "type": "string" },
        "statusCode": { "$ref": "#/$defs/statusCode" }
      }
    },
    "browseResult": {
      "type": "object",
      "required": ["referenceTypeId", "isForward", "nodeId", "browseName", "displayName", "nodeClass"],
      "additionalProperties": false,
      "properties": {
        "referenceTypeId": { "type": "string" },
        "isForward":       { "type": "boolean" },
        "nodeId":          { "type": "string" },
        "browseName": {
          "type": "object",
          "required": ["ns", "name"],
          "properties": {
            "ns":   { "type": "integer" },
            "name": { "type": "string" }
          }
        },
        "displayName": {
          "type": "object",
          "required": ["locale", "text"],
          "properties": {
            "locale": { "type": "string" },
            "text":   { "type": "string" }
          }
        },
        "nodeClass": {
          "type": "string",
          "enum": ["Object","Variable","Method","ObjectType","VariableType","ReferenceType","DataType","View"]
        }
      }
    },
    "subscribeResult": {
      "type": "object",
      "required": ["nodeId", "subscriptionId", "revisedPublishingInterval", "revisedLifetimeCount", "revisedMaxKeepAliveCount", "monitoredItemStatusCode", "notifications"],
      "additionalProperties": false,
      "properties": {
        "nodeId":                    { "type": "string" },
        "subscriptionId":            { "type": "integer", "minimum": 0 },
        "revisedPublishingInterval": { "type": "number" },
        "revisedLifetimeCount":      { "type": "integer", "minimum": 0 },
        "revisedMaxKeepAliveCount":  { "type": "integer", "minimum": 0 },
        "monitoredItemStatusCode":   { "$ref": "#/$defs/statusCode" },
        "notifications": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sequenceNumber", "value", "dataType", "builtInType", "statusCode"],
            "properties": {
              "sequenceNumber":  { "type": "integer" },
              "value":           {},
              "dataType":        { "type": "string" },
              "builtInType":     { "type": "integer" },
              "statusCode":      { "$ref": "#/$defs/statusCode" },
              "sourceTimestamp": { "type": "string" },
              "serverTimestamp": { "type": "string" }
            }
          }
        }
      }
    },
    "subscriptionLifecycleResult": {
      "type": "object",
      "required": ["subscriptionId"],
      "properties": {
        "subscriptionId":              { "type": "integer", "minimum": 0 },
        "requestedPublishingInterval": { "type": "number" },
        "requestedLifetimeCount":      { "type": "integer" },
        "requestedMaxKeepAliveCount":  { "type": "integer" },
        "revisedPublishingInterval":   { "type": "number" },
        "revisedLifetimeCount":        { "type": "integer", "minimum": 0 },
        "revisedMaxKeepAliveCount":    { "type": "integer", "minimum": 0 },
        "overflow":                    { "type": "boolean" },
        "values":                      { "type": "array", "items": { "type": "integer" } },
        "modeSteps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["mode", "notificationCount"],
            "properties": {
              "mode":              { "type": "string" },
              "notificationCount": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "deleteMonitoredItem": {
          "type": "object",
          "required": ["first", "second"],
          "properties": {
            "first":  { "$ref": "#/$defs/statusCode" },
            "second": { "$ref": "#/$defs/statusCode" }
          }
        },
        "deleteSubscription": {
          "type": "object",
          "required": ["first", "second"],
          "properties": {
            "first":  { "$ref": "#/$defs/statusCode" },
            "second": { "$ref": "#/$defs/statusCode" }
          }
        }
      }
    },
    "eventSubscribeResult": {
      "type": "object",
      "required": ["nodeId", "subscriptionId", "revisedPublishingInterval", "monitoredItemStatusCode", "selectClauses", "events"],
      "additionalProperties": false,
      "properties": {
        "nodeId":                    { "type": "string" },
        "subscriptionId":            { "type": "integer", "minimum": 0 },
        "revisedPublishingInterval": { "type": "number" },
        "monitoredItemStatusCode":   { "$ref": "#/$defs/statusCode" },
        "selectClauses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["sequenceNumber", "fields"],
            "properties": {
              "sequenceNumber": { "type": "integer" },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "dataType", "builtInType", "value"],
                  "properties": {
                    "name":         { "type": "string" },
                    "dataType":     { "type": "string" },
                    "builtInType":  { "type": "integer" },
                    "value":        {}
                  }
                }
              }
            }
          }
        }
      }
    },
    "historyReadResult": {
      "type": "object",
      "required": ["nodeId", "statusCode", "continuationPoint", "values"],
      "additionalProperties": false,
      "properties": {
        "nodeId":            { "type": "string" },
        "statusCode":        { "$ref": "#/$defs/statusCode" },
        "continuationPoint": {
          "oneOf": [
            { "type": "null" },
            { "type": "string" }
          ]
        },
        "values": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["value", "dataType", "builtInType", "statusCode"],
            "properties": {
              "value":           {},
              "dataType":        { "type": "string" },
              "builtInType":     { "type": "integer" },
              "statusCode":      { "$ref": "#/$defs/statusCode" },
              "sourceTimestamp": { "type": "string" },
              "serverTimestamp": { "type": "string" }
            }
          }
        }
      }
    },
    "republishResult": {
      "type": "object",
      "required": ["subscriptionId", "retransmitSequenceNumber"],
      "additionalProperties": false,
      "properties": {
        "subscriptionId":           { "type": "integer", "minimum": 0 },
        "retransmitSequenceNumber": { "type": "integer", "minimum": 0 },
        "sequenceNumber":           { "type": "integer", "minimum": 0 },
        "publishTime":              { "type": "string" },
        "notificationDataCount":    { "type": "integer", "minimum": 0 }
      }
    },
    "transferSubscriptionsResult": {
      "type": "object",
      "required": ["subscriptionId", "statusCode", "availableSequenceNumbers"],
      "additionalProperties": false,
      "properties": {
        "subscriptionId": { "type": "integer", "minimum": 0 },
        "statusCode":     { "$ref": "#/$defs/statusCode" },
        "availableSequenceNumbers": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
